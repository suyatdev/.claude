# macOS
.DS_Store

# Runtime state & update artifacts
.last-cleanup
.last-update-result.json

# Statusline cumulative-token counters (machine-specific, regenerable)
/statusline-state/

# Pane-orchestration runtime state (session flags + per-run launchers, which
# contain copied prompts — machine-local, never committed)
/panes/state/

# Backup files
settings.json.bak
backups/

# Cache & downloaded content
cache/
downloads/

# Conversation and session history (machine-specific, potentially sensitive)
history.jsonl
sessions/
session-env/
shell-snapshots/

# IDE lock files (machine-specific)
ide/

# Plugin cache & marketplace data (reinstallable, machine-specific)
plugins/

# Auth/session caches (machine-specific, potentially sensitive)
mcp-needs-auth-cache.json

# Project-specific local data (contains absolute local paths)
projects/

# Task runner data (machine-specific)
tasks/

# Background daemon state (machine-specific, potentially sensitive)
# Anchored to repo root (leading /) so these don't shadow same-named
# directories elsewhere in the tree, e.g. docs/superpowers/plans/.
/daemon/
/daemon.lock
/daemon.log
/daemon.status.json

# Local job queue & plan-mode scratch state (machine-specific)
/jobs/
/plans/

# Paste and file-edit history (machine-specific, potentially sensitive)
/paste-cache/
/file-history/

# GitHub PR status cache (machine-specific)
/gh-pr-status-cache.json

# memsearch index cache (regenerable, potentially sensitive)
/memory-index/

# claude-code-handoff session state (this repo is itself a git toplevel, so the
# vendored handoff hooks write their session files to a nested .claude/ here)
/.claude/
