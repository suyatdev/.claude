{
  "permissions": {
    "defaultMode": "acceptEdits"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/git-guard.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/doc-guard.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/judge-guard.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/doc-guard.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/memsearch-nudge.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/handoff/pre-compact.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/handoff/proactive-handoff.sh save"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/handoff/pre-compact-handoff.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/handoff/live-handoff.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/handoff/post-edit-hook.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline-command.sh\""
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "editorMode": "normal",
  "preferredNotifChannel": "iterm2",
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true
}
